# ######### 基础配置 #########

# 服务器的对外 IP（WuKongIM 等上报用）
EXTERNAL_IP=YOUR_PUBLIC_IP

# mysql root 用户密码（部署时请自行修改）
MYSQL_ROOT_PASSWORD=CHANGE_ME

# mysql 默认数据库名字
MYSQL_DATABASE=im

# ######### Minio 文件服务配置 #########

# minio 文件服务用户名
MINIO_ROOT_USER=minio

# minio 文件服务密码（部署时请自行修改）
MINIO_ROOT_PASSWORD=CHANGE_ME

######### WuKongIM 相关的配置 #########

# 模式 debug or release
WK_MODE=release

# 开启最近会话服务端维护
WK_CONVERSATION_ON=true

# 业务服务的 grpc 地址（与 compose 服务名 server 一致）
WK_WEBHOOK_GRPCADDR=server:6979

# 业务服务的数据源地址
WK_DATASOURCE_ADDR=http://server:8090/v1/datasource

# 开启频道信息同步
WK_DATASOURCE_CHANNELINFOON=true

# 开启 token 认证
WK_TOKENAUTHON=true

# 是否关闭个人白名单功能（默认开启；关闭后发送消息将不做好友关系判断）
WK_WHITELISTOFFOFPERSON=false

# JWT 的密钥（部署时请自行修改）
WK_JWT_SECRET=CHANGE_ME

######### TangSengDaoDao 的配置 #########

# 模式 debug or release
TS_MODE=release

# wukongim 的内网访问地址
TS_WUKONGIM_APIURL=http://wukongim:5001

# redis 连接地址
TS_DB_REDISADDR=redis:6379

# 验证码：如果不为空则使用此值作为验证码；为空则走短信提供商
TS_SMSCODE=123456

# 使用文件服务类型（minio/oss/qiniu/seaweedfs）
TS_FILESERVICE=minio

# 默认头像 base url（不要填公网 URL，避免 302 到外网）
TS_AVATAR_DEFAULTBASEURL=

# 小龙虾后台管理系统管理员密码（部署时请自行修改）
TS_ADMINPWD=CHANGE_ME

# 容器内上传用内网地址（服务名）
TS_MINIO_UPLOADURL=http://minio:9000

# 客户端访问对象存储的公网地址（域名需解析到本机并放行 9000）
TS_MINIO_DOWNLOADURL=http://YOUR_PUBLIC_IP:9000

# 可选：后台任务（如群头像拼图）本机拉 /v1/users/*/avatar.png 时用；
# 不设则按监听地址推导为 http://127.0.0.1:8090/v1
#
# TS_INTERNAL_API_BASE_URL=http://127.0.0.1:8090/v1

# Web 端：Nginx 将 /api 转发到后端，必须填且末尾加 /
API_URL=http://server:8090/

